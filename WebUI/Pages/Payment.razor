                    </div>

                </div>

                <!-- Order Summary -->
                <div class="summary-card" style="max-width: 100%;">
                    <h3 class="summary-header">Tóm tắt đơn hàng</h3>
                    <div class="summary-divider"></div>
                    <div class="summary-row">
                        <span class="summary-label">Tạm tính</span>
                        <span class="summary-value">@SubTotal.ToString("N0")đ</span>
                    </div>
                    <div class="summary-row">
                        <span class="summary-label">Phí vận chuyển</span>
                        <span class="summary-value">@ShippingFee.ToString("N0")đ</span>
                    </div>
                    @if (Discount > 0)
                    {
                        <div class="summary-row discount">
                            <span class="summary-label">Giảm giá</span>
                            <span class="summary-value">-@Discount.ToString("N0")đ</span>
                        </div>
                    }
                    <div class="summary-divider"></div>
                    <div class="summary-row total">
                        <span class="summary-label">Tổng cộng</span>
                        <span class="summary-value">@GetFinalTotal()</span>
                    </div>
                    <div class="terms-section">
                        <input type="checkbox" class="terms-checkbox" @bind="AgreeTerms" id="agreeTerms" />
                        <label for="agreeTerms" class="terms-text">
                            Tôi đồng ý với <a href="#" class="terms-link">Điều khoản & Điều kiện</a> của Asion
                        </label>
